# autoreel — env template (safe to commit). Copy to .env and fill.

# TELEGRAM
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_API_BASE_URL=http://localhost:8081

# INSTAGRAM (Instagram API with Instagram Login — host is graph.instagram.com)
IG_GRAPH_BASE_URL=https://graph.instagram.com
IG_ACCESS_TOKEN=
IG_USER_ID=
IG_APP_ID=
IG_APP_SECRET=

# SUPABASE
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=reels

# ANTHROPIC (optional — usually runs via Claude Code subscription)
# ANTHROPIC_API_KEY=
